DATABASE_URL=your_neon_connection_string_here
PORT=3004
BOT_TOKEN=your_telegram_bot_token
# VPS default: polling is enabled automatically when ENABLE_TELEGRAM_POLLING is unset.
# Set explicitly to false if you only want webhook mode.
ENABLE_TELEGRAM_POLLING=
BOT_LOG_ALL_UPDATES=false

# CORS (use "*" or comma-separated origins)
CORS_ORIGIN=*

# Vercel/Telegram webhook bot
# BACKEND_URL should be your deployed base URL (for local: http://localhost:3004)
BACKEND_URL=http://localhost:3004
# Optional: if you don't want to infer from request headers
PUBLIC_BASE_URL=http://localhost:3004
# Optional: Railway provides a public domain env var you can reuse for BACKEND_URL/PUBLIC_BASE_URL
RAILWAY_PUBLIC_DOMAIN=

# Polling-only mode helpers
# If the bot token previously had a webhook set, polling will fail unless the webhook is deleted.
TELEGRAM_CLEAR_WEBHOOK_ON_POLLING=true
# Optional: override where the bot sends its backend API requests (defaults to 127.0.0.1 when polling locally)
BOT_BACKEND_URL=
# Optional: bot HTTP timeout for backend API calls (ms)
BOT_HTTP_TIMEOUT_MS=60000

# Optional: protect cron endpoint (if x-vercel-cron header isn't present)
CRON_SECRET=
# Optional: the bot username for deep-linking in cron nudges (no @)
BOT_USERNAME=yourbot

# Telegram Mini App
# Public HTTPS base URL where the backend is reachable from Telegram (no trailing slash).
# Example (ngrok): https://abcd-1234.ngrok-free.app
MINIAPP_PUBLIC_URL=
# Optional: ngrok token (used by `npm run tunnel:miniapp`)
NGROK_AUTHTOKEN=
# Optional: local proxy config (used by `npm run miniapp:proxy`)
MINIAPP_PROXY_PORT=3111
MINIAPP_TARGET_PORT=3004
# Optional: cloudflared binary path override (used by `npm run tunnel:miniapp:cloudflare`)
CLOUDFLARED_BIN=
# Init data max age (seconds) for Mini App auth
MINIAPP_INITDATA_MAX_AGE_SECONDS=86400
# Telegram group IDs allowed to use internal intel commands (/run, /top)
# Example: -1001234567890,-1009876543210
INTERNAL_GROUP_IDS=
# If true, allow workspace commands in any group where the bot is an admin
# (and the user running the command is an admin). Safer default is to leave this false
# and explicitly allowlist groups via INTERNAL_GROUP_IDS.
ALLOW_ANY_GROUP_WORKSPACE=false
# Optional: daily cron to auto-run workspace intel + post results to internal groups
ENABLE_WORKSPACE_AUTO_RUN=false
# Back-compat (prefer ENABLE_WORKSPACE_AUTO_RUN)
ENABLE_WORKSPACE_DAILY_RUN=false
# VPS/local scheduler cron expression (Vercel uses vercel.json)
WORKSPACE_AUTO_RUN_CRON=0 */10 * * *
# Optional: minimum time between enqueues
WORKSPACE_ENQUEUE_MIN_HOURS=6
# Optional: lock duration to avoid overlapping runs (seconds)
WORKSPACE_AUTO_RUN_LOCK_SECONDS=300
# Don't enqueue if a successful run happened recently
WORKSPACE_AUTO_RUN_MIN_HOURS=10
# Local (non-Vercel) runner tick for queued jobs
ENABLE_WORKSPACE_RUNNER_SCHEDULER=true
WORKSPACE_DAILY_RUN_SEARCH=false
# Daily nudge tuning
DAILY_NUDGE_ONLY_TOP=10
DAILY_NUDGE_MAX_USERS=50

# Default communities for ingestion (comma-separated Telegram usernames or t.me links)
# Example: @somegroup,@anothergroup or https://t.me/somegroup
INTEL_COMMUNITIES=

# Web discovery via Crawlee (search/discovery only)
CRAWLEE_SEARCH_ENGINE=duckduckgo
CRAWLEE_SEARCH_TIMEOUT_MS=12000
CRAWLEE_SEARCH_PAGES_PER_QUERY=3
CRAWLEE_SEARCH_MAX_LINKS=50
# Optional: offload Crawlee discovery to a separate service (recommended for non-serverless)
CRAWLEE_SERVICE_URL=
CRAWLEE_SERVICE_API_KEY=
CRAWLEE_SERVICE_TIMEOUT_MS=12000
TELEGRAM_HTTP_TIMEOUT_MS=8000

# Public cron runner throttle (seconds)
INTEL_RUNNER_THROTTLE_SECONDS=30
# Optional: comma-separated keywords used for matching (defaults: game,play,1v1,bet,earn)
INTEL_KEYWORDS=game,play,1v1,bet,earn
# Optional: intent keywords (comma-separated)
INTEL_INTENT_KEYWORDS=any game,recommend,looking for,what to play
# Optional: promotion keywords (comma-separated)
INTEL_PROMO_KEYWORDS=join,play,win,earn,invite,reward,contest,launch,airdrop
# Optional: activity keywords (comma-separated)
INTEL_ACTIVITY_KEYWORDS=game,play,mission,race,earn,token
# Optional: platforms (comma-separated)
INTEL_PLATFORMS=telegram
# Optional: Telethon microservice (Telegram discovery + message ingestion)
TELETHON_SERVICE_URL=
TELETHON_SERVICE_API_KEY=
TELETHON_SERVICE_TIMEOUT_MS=25000
# Thresholds / hygiene
INTEL_INTENT_THRESHOLD=2
INTEL_TRENDING_SPIKE_RATIO=1.5
INTEL_POST_TTL_DAYS=30
# Cost/time controls
INTEL_MAX_COMMUNITIES_PER_RUN=20
INTEL_MAX_MESSAGES_PER_COMMUNITY=50
INTEL_PIPELINE_TIMEOUT_MS=8000
# Optional: JSON config override
INTEL_CONFIG_JSON=
# Optional: internal alerts (admin only)
INTEL_ALERT_TELEGRAM_CHAT_ID=
# Protect client-facing intel APIs (opportunities/runs/webhook registration)
INTEL_API_KEY=
# Sandbox mode for demos (no real ingestion, mock outputs)
INTEL_SANDBOX=false
# Optional: extra debug logging
INTEL_DEBUG=false

# AI community analysis (optional post-processing)
# Provider: openai (default), groq, grok
AI_PROVIDER=openai
# Optional: generic API key override (otherwise uses provider-specific vars below)
AI_API_KEY=
# Optional: override base URL for OpenAI-compatible providers
AI_BASE_URL=
# Optional: override model (otherwise uses provider-specific model vars below)
AI_MODEL=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=
GROQ_MODEL=
XAI_API_KEY=
XAI_MODEL=
AI_ANALYSIS_TTL_HOURS=24
AI_ANALYSIS_TIMEOUT_MS=12000
AI_ANALYSIS_SAMPLE_SIZE=10
AI_ANALYSIS_MAX_RETRIES=2

# Optional: discovery layer controls
INTEL_DISCOVERY_ENABLED=false
INTEL_DISCOVERY_SCRAPE_COOLDOWN_HOURS=12
INTEL_DISCOVERY_MAX_SCRAPES_PER_RUN=5
INTEL_DISCOVERY_MESSAGE_WINDOW_HOURS=72
INTEL_DISCOVERY_MESSAGE_MAX_POSTS=5000

BIG_WIN_THRESHOLD=100
STREAK_THRESHOLD=3

ENABLE_WEEKLY_LEADERBOARD=false
WEEKLY_LEADERBOARD_CRON=0 18 * * 0

ENABLE_LEADERBOARD_HYPE=true
LEADERBOARD_HYPE_COOLDOWN_MS=30000
LEADERBOARD_HYPE_TOP_N=10

# Optional: run safe schema ensures on startup (tables/columns for matches, tournaments, tiers)
AUTO_INIT_DB=false

# Optional: allow tournament seeding even when NODE_ENV=production
ALLOW_SEED_TOURNAMENTS=false

# Optional: Apify dataset ingestion (comma-separated IDs or a single ID)
APIFY_DATASET_ID=
APIFY_DATASET_IDS=

# Optional: Telethon ingestion tuning
TELETHON_COMMUNITIES=
TELETHON_MAX_MESSAGES_PER_GROUP=

# Bot-only (if running bot scripts from this repo root)
GROUP_ID=
DEBUG_CHAT_ID=
ENABLE_GROUP_FALLBACK=
