# Kickchain backend
PORT=3004
NODE_ENV=production

DATABASE_URL=
BOT_TOKEN=
CORS_ORIGIN=*
ENABLE_TELEGRAM_POLLING=true

BACKEND_URL=https://api.example.com
PUBLIC_BASE_URL=https://api.example.com

CRON_SECRET=
BOT_USERNAME=
TELEGRAM_CLEAR_WEBHOOK_ON_POLLING=true
BOT_BACKEND_URL=
BOT_HTTP_TIMEOUT_MS=60000

INTERNAL_GROUP_IDS=
ENABLE_WORKSPACE_AUTO_RUN=false
# Back-compat (prefer ENABLE_WORKSPACE_AUTO_RUN)
ENABLE_WORKSPACE_DAILY_RUN=false
WORKSPACE_AUTO_RUN_CRON=0 */10 * * *
WORKSPACE_AUTO_RUN_MIN_HOURS=10
ENABLE_WORKSPACE_RUNNER_SCHEDULER=true
WORKSPACE_DAILY_RUN_SEARCH=false

# Intel
INTEL_API_KEY=
INTEL_SANDBOX=false

# Default communities (comma-separated)
INTEL_COMMUNITIES=

# Telethon microservice
TELETHON_SERVICE_URL=http://telethon:8000
TELETHON_SERVICE_API_KEY=
TELETHON_SERVICE_TIMEOUT_MS=25000

# Crawlee microservice (optional). If empty, backend will run Crawlee locally.
CRAWLEE_SERVICE_URL=http://crawlee:8002
CRAWLEE_SERVICE_API_KEY=
CRAWLEE_SERVICE_TIMEOUT_MS=12000
CRAWLEE_SEARCH_ENGINE=duckduckgo
CRAWLEE_SEARCH_TIMEOUT_MS=12000

# AI
AI_PROVIDER=openai
AI_BASE_URL=
AI_MODEL=
GROQ_API_KEY=
XAI_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_ANALYSIS_TTL_HOURS=24
AI_ANALYSIS_TIMEOUT_MS=12000
AI_ANALYSIS_SAMPLE_SIZE=10
AI_ANALYSIS_MAX_RETRIES=2
